---
import Container from "../shared/Container.astro";
import FooterNav from "../shared/FooterNav.astro";
import Paragraph from "../shared/Paragraph.astro";
import logo from "../../../public/logos/logo3.png";

const footerLinks = [
    {
        itemText:"Início",
        itemLink:"#home"
    },
    {
        itemText:"Serviços",
        itemLink:"#services"
    },
    {
        itemText:"Quem somos",
        itemLink:"#about-us"
    },
    {
        itemText:"Blog",
        itemLink:"#blog"
    },
    {
        itemText:"Contato",
        itemLink:"#contact"
    }
]
---

<div class="mt-16"></div>

<footer class="relative bg-gradient-to-tr from-gray-100 to-gray-200 dark:from-gray-900 dark:to-transparent pt-28 rounded-t-3xl">

    <!-- EFEITOS -->
    <div class="absolute right-0 top-0 h-full w-full flex justify-end">
        <div class="w-28 h-28 overflow-auto flex rounded-xl relative blur-2xl">
            <span class="absolute w-16 h-16 -top-1 -right-1 bg-green-500 rounded-md rotate-45"></span>
            <span class="absolute w-16 h-16 -bottom-1 -right-1 bg-[#FCDC58] rounded-md rotate-45"></span>
            <span class="absolute w-16 h-16 -bottom-1 -left-1 bg-primary rounded-md rotate-45"></span>
        </div>
    </div>

    <div class="absolute left-0 bottom-0 h-full w-full flex items-end">
        <div class="w-28 h-28 overflow-auto flex rounded-xl relative blur-2xl">
            <span class="absolute w-16 h-16 -top-1 -right-1 bg-green-500 rounded-md rotate-45"></span>
            <span class="absolute w-16 h-16 -bottom-1 -right-1 bg-[#FCDC58] rounded-md rotate-45"></span>
            <span class="absolute w-16 h-16 -bottom-1 -left-1 bg-primary rounded-md rotate-45"></span>
        </div>
    </div>

    <Container className="pb-8 relative overflow-auto">

        <span class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 blur-2xl opacity-20 w-24 h-16 sm:w-48 sm:h-36 rounded-full rotate-12 skew-x-6 bg-primary"></span>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 relative">

            <!-- LOGO / DESCRIÇÃO -->
            <div class="flex flex-col">
                    
                <img 
                    src={logo.src}
                    alt="Pamela Marketing"
                    class="w-14 h-14 object-contain"
                />

                <Paragraph className={"mt-8"}>
                    A ZENTRY conecta marketing, mídia e tecnologia para criar estratégias que fortalecem marcas e geram resultados reais.
                </Paragraph>
                <!-- ÍCONES SOCIAIS -->
                <div class="min-h-max flex items-center gap-4 text-heading-3 mt-8">

                    <!-- WhatsApp -->
                    <a 
                        href="https://wa.me/5592999999999"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="transition hover:text-heading-1 hover:scale-105"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="w-5 h-5" viewBox="0 0 16 16">
                            <path d="M13.601 2.326A7.854 7.854 0 0 0 8.01 0C3.602 0 .016 3.582.016 7.99a7.95 7.95 0 0 0 1.077 3.978L0 16l4.157-1.09a7.98 7.98 0 0 0 3.852.984h.003c4.408 0 7.994-3.582 7.994-7.99a7.93 7.93 0 0 0-2.405-5.578zM8.01 14.55a6.58 6.58 0 0 1-3.35-.92l-.24-.142-2.466.647.658-2.404-.156-.247A6.55 6.55 0 0 1 1.45 7.99c0-3.62 2.944-6.565 6.56-6.565 1.754 0 3.403.683 4.64 1.922a6.5 6.5 0 0 1 1.92 4.643c-.002 3.618-2.946 6.56-6.56 6.56zm3.6-4.916c-.197-.099-1.17-.578-1.352-.643-.181-.066-.313-.099-.445.099-.132.198-.511.643-.626.775-.115.132-.23.148-.428.05-.197-.099-.832-.307-1.585-.98-.586-.523-.981-1.17-1.096-1.368-.115-.198-.012-.305.087-.403.09-.09.198-.23.296-.346.099-.115.132-.198.198-.33.066-.132.033-.247-.017-.346-.05-.099-.445-1.074-.61-1.47-.161-.387-.325-.334-.445-.34l-.379-.007c-.132 0-.346.05-.527.247-.181.198-.692.676-.692 1.648 0 .973.709 1.912.808 2.044.099.132 1.396 2.133 3.384 2.99.473.204.842.326 1.13.417.475.151.907.13 1.248.079.381-.057 1.17-.478 1.336-.94.165-.462.165-.858.115-.94-.05-.083-.181-.132-.379-.23z"/>
                        </svg>
                    </a>

                    <!-- Instagram -->
                    <a 
                        href="https://www.instagram.com/zentry_oficial/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="transition hover:text-heading-1 hover:scale-105"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="w-5 h-5" viewBox="0 0 16 16">
                            <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.93 3.93 0 0 0-1.417.923A3.93 3.93 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.702.01 5.555 0 5.827 0 8c0 2.172.01 2.444.048 3.297.039.852.174 1.434.372 1.943.205.527.478.974.923 1.417.444.445.89.718 1.417.923.509.198 1.09.333 1.943.372C5.556 15.99 5.828 16 8 16c2.172 0 2.444-.01 3.297-.048.852-.039 1.434-.174 1.943-.372a3.93 3.93 0 0 0 1.417-.923 3.93 3.93 0 0 0 .923-1.417c.198-.509.333-1.09.372-1.943C15.99 10.444 16 10.172 16 8c0-2.173-.01-2.445-.048-3.298-.039-.851-.174-1.433-.372-1.942a3.93 3.93 0 0 0-.923-1.417A3.93 3.93 0 0 0 13.24.42c-.509-.198-1.09-.333-1.943-.372C10.444.01 10.172 0 8 0zm0 1.441c2.136 0 2.389.008 3.232.046.78.036 1.204.166 1.486.276.373.145.64.318.92.598.28.28.453.547.598.92.11.282.24.706.276 1.486.038.843.046 1.096.046 3.233s-.008 2.389-.046 3.232c-.036.78-.166 1.204-.276 1.486a2.49 2.49 0 0 1-.598.92 2.49 2.49 0 0 1-.92.598c-.282.11-.706.24-1.486.276-.843.038-1.096.046-3.232.046s-2.389-.008-3.233-.046c-.78-.036-1.204-.166-1.486-.276a2.49 2.49 0 0 1-.92-.598 2.49 2.49 0 0 1-.598-.92c-.11-.282-.24-.706-.276-1.486C1.45 10.389 1.441 10.136 1.441 8s.009-2.39.046-3.233c.036-.78.166-1.204.276-1.486.145-.373.318-.64.598-.92.28-.28.547-.453.92-.598.282-.11.706-.24 1.486-.276.844-.038 1.097-.046 3.233-.046zm0 2.459A4.1 4.1 0 1 0 8 12.1 4.1 4.1 0 0 0 8 3.9zm0 6.765A2.665 2.665 0 1 1 8 5.335a2.665 2.665 0 0 1 0 5.33zm4.27-7.845a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92z"/>
                        </svg>
                    </a>

                    <!-- E-mail -->
                    <a 
                        href="mailto:Zentryoficial1@gmail.com"
                        class="transition hover:text-heading-1 hover:scale-105"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="w-5 h-5" viewBox="0 0 16 16">
                            <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-.5a.5.5 0 0 0-.5.5v.217l6.5 4.333 6.5-4.333V4a.5.5 0 0 0-.5-.5H2zm13 2.383-4.708 3.138L15 12.117V5.883zm-.803 7.617-4.965-3.31-1.232.821-1.232-.821-4.965 3.31A.5.5 0 0 0 2 13.5h12a.5.5 0 0 0 .197-.04zM1 12.117l4.708-3.096L1 5.883v6.234z"/>
                        </svg>
                    </a>

                </div>

            </div>
            <!-- CONTATO -->
            <div class="space-y-6">

                <div>
                    <h3 class="text-xl font-semibold text-heading-1 mb-5">
                        Contato
                    </h3>

                    <div class="space-y-4 text-heading-3">

                        <a 
                              href="https://wa.me/5592988258819?text=Olá,%20quero%20solicitar%20um%20orçamento%20para%20minha%20empresa."
                            target="_blank"
                            rel="noopener noreferrer"
                            class="block hover:text-primary transition"
                        >
                            WhatsApp
                        </a>

                        <a 
                            href="https://www.instagram.com/zentry_oficial/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="block hover:text-primary transition"
                        >
                            Instagram
                        </a>

                        <a 
                            href="mailto:contato@zentry.com.br"
                            class="block hover:text-primary transition"
                        >
                            contato@zentry.com.br
                        </a>

                    </div>

                  <a
                    href="https://wa.me/5592988258819?text=Olá,%20quero%20solicitar%20um%20orçamento%20para%20minha%20empresa."
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-8 inline-flex items-center justify-center gap-3 px-6 py-3 rounded-xl bg-primary text-white font-medium hover:opacity-90 transition"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        fill="currentColor"
                        viewBox="0 0 16 16"
                        class="w-5 h-5"
                    >
                        <path d="M13.601 2.326A7.854 7.854 0 0 0 8.002 0C3.58 0 0 3.58 0 8c0 1.409.369 2.786 1.07 4l-1 3.646 3.733-.98A7.96 7.96 0 0 0 8 16h.003c4.42 0 8-3.58 8-8a7.94 7.94 0 0 0-2.402-5.674zM8.003 14.5a6.48 6.48 0 0 1-3.303-.902l-.237-.14-2.215.582.592-2.157-.154-.222A6.47 6.47 0 0 1 1.5 8a6.5 6.5 0 1 1 6.503 6.5zm3.59-4.865c-.197-.099-1.17-.578-1.352-.644-.181-.066-.313-.099-.445.1-.131.197-.51.644-.626.776-.115.132-.23.149-.427.05-.197-.099-.833-.307-1.588-.98-.588-.524-.985-1.17-1.1-1.368-.116-.197-.012-.304.087-.402.09-.09.198-.23.297-.346.099-.116.132-.198.198-.33.066-.132.033-.248-.017-.347-.05-.099-.445-1.074-.61-1.47-.161-.387-.325-.334-.445-.34l-.379-.007c-.132 0-.347.05-.528.248-.181.197-.693.677-.693 1.652s.71 1.918.809 2.05c.099.132 1.397 2.134 3.386 2.992.473.204.842.326 1.13.417.475.151.907.13 1.249.079.381-.057 1.17-.479 1.336-.941.165-.463.165-.859.115-.941-.05-.083-.181-.132-.379-.231z"/>
                    </svg>

                    <span>Solicitar orçamento</span>
                </a>

                </div>

            </div>

            <!-- LINKS RÁPIDOS -->
            <div>
                <FooterNav
                    title={"Links rápidos"}
                    navItems={footerLinks}
                />
            </div>

        </div>

    </Container>

    <!-- COPYRIGHT -->
    <div class="bg-gradient-to-tl from-box-bg py-4 relative border-t border-gray-200/10">

        <Container>

            <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm md:text-base text-heading-3">

                <div>
                    &copy; <span id="year"></span> ZENTRY. Todos os direitos reservados.
                </div>

                <div class="text-center md:text-right">
                    Feito por
                    <a href="https://github.com/kev1nnnnnnn" target="_blank" class="font-semibold hover:text-primary transition">
                        John Oliveira
                    </a>
                    •
                    Criado por
                    <a href="https://oliver-tech.vercel.app/" target="_blank" class="font-semibold hover:text-primary transition">
                        KSOFT Solutions
                    </a>
                </div>

            </div>

        </Container>

    </div>

</footer>