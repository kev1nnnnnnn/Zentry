---
import Button from "../shared/Button.astro";
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
---

<section id="cta" class="pb-20">
    <Container>

        <div
            class="w-full relative overflow-hidden py-10 md:py-14 px-6 md:px-10 rounded-3xl bg-gradient-to-tr from-gray-100 to-gray-200 dark:from-gray-900 dark:to-transparent"
        >

            <!-- EFEITOS -->
            <div class="absolute right-0 top-0 h-full w-full flex justify-end pointer-events-none">
                <div class="w-32 h-32 flex rounded-xl relative blur-3xl opacity-70">

                    <span
                        class="absolute w-20 h-20 -top-1 -right-1 bg-green-500 rounded-md rotate-45"
                    ></span>

                    <span
                        class="absolute w-20 h-20 -bottom-1 -right-1 bg-[#FCDC58] rounded-md rotate-45"
                    ></span>

                    <span
                        class="absolute w-20 h-20 -bottom-1 -left-1 bg-primary rounded-md rotate-45"
                    ></span>

                </div>
            </div>

            <div class="absolute left-0 bottom-0 h-full w-full flex items-end pointer-events-none">
                <div class="w-32 h-32 flex rounded-xl relative blur-3xl opacity-70">

                    <span
                        class="absolute w-20 h-20 -top-1 -right-1 bg-green-500 rounded-md rotate-45"
                    ></span>

                    <span
                        class="absolute w-20 h-20 -bottom-1 -right-1 bg-[#FCDC58] rounded-md rotate-45"
                    ></span>

                    <span
                        class="absolute w-20 h-20 -bottom-1 -left-1 bg-primary rounded-md rotate-45"
                    ></span>

                </div>
            </div>

            <!-- CONTEÚDO -->
            <div class="mx-auto text-center max-w-xl md:max-w-3xl relative z-10">

                <h2
                    class="text-3xl/tight sm:text-4xl/tight md:text-5xl/tight font-bold text-heading-1"
                >
                    Sua empresa pronta para crescer com
                    <span class="text-transparent bg-clip-text bg-gradient-to-br from-indigo-600 from-20% via-primary via-30% to-green-600">
                        estratégia
                    </span>.
                </h2>

                <Paragraph className={"pt-8 text-base md:text-lg"}>
                    A <strong>ZENTRY</strong> está preparada para transformar sua marca através de marketing, mídia e tecnologia.
                </Paragraph>

                <div class="mx-auto max-w-md sm:max-w-xl pt-10 flex justify-center">

                    <a
                        href="https://wa.me/5592988258819?text=Olá,%20quero%20falar%20com%20a%20equipe%20da%20ZENTRY"
                        target="_blank"
                    >

                        <Button variant={"primary"}>

                            <span class="text-white relative z-[5] flex items-center gap-3">

                                <!-- ÍCONE WHATSAPP -->
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="22"
                                    height="22"
                                    fill="currentColor"
                                    viewBox="0 0 16 16"
                                    class="w-5 h-5"
                                >
                                    <path d="M13.601 2.326A7.854 7.854 0 0 0 8.002 0C3.58 0 0 3.58 0 8c0 1.409.369 2.786 1.07 4l-1 3.646 3.733-.98A7.96 7.96 0 0 0 8 16h.003c4.42 0 8-3.58 8-8a7.94 7.94 0 0 0-2.402-5.674zM8.003 14.5a6.48 6.48 0 0 1-3.303-.902l-.237-.14-2.215.582.592-2.157-.154-.222A6.47 6.47 0 0 1 1.5 8a6.5 6.5 0 1 1 6.503 6.5zm3.59-4.865c-.197-.099-1.17-.578-1.352-.644-.181-.066-.313-.099-.445.1-.131.197-.51.644-.626.776-.115.132-.23.149-.427.05-.197-.099-.833-.307-1.588-.98-.588-.524-.985-1.17-1.1-1.368-.116-.197-.012-.304.087-.402.09-.09.198-.23.297-.346.099-.116.132-.198.198-.33.066-.132.033-.248-.017-.347-.05-.099-.445-1.074-.61-1.47-.161-.387-.325-.334-.445-.34l-.379-.007c-.132 0-.347.05-.528.248-.181.197-.693.677-.693 1.652s.71 1.918.809 2.05c.099.132 1.397 2.134 3.386 2.992.473.204.842.326 1.13.417.475.151.907.13 1.249.079.381-.057 1.17-.479 1.336-.941.165-.463.165-.859.115-.941-.05-.083-.181-.132-.379-.231z"/>
                                </svg>

                                <span>
                                    Fale com nossa equipe
                                </span>

                            </span>

                        </Button>

                    </a>

                </div>

            </div>

        </div>

    </Container>
</section>