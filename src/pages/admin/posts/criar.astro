---
import "../../../styles/global.css";
import Layout from "../../../layouts/Layout.astro";
import Container from "../../../components/shared/Container.astro";
---

<Layout title="Admin - Criar Post">

<main class="pt-32 pb-24 min-h-screen bg-body">

  <Container>

    <!-- HEADER -->
    <header class="mb-10">
      <h1 class="text-4xl font-bold text-heading-1">
        Painel <span class="text-primary">CMS</span>
      </h1>

      <p class="text-heading-3 mt-2">
        Criação simplificada de artigos
      </p>
    </header>

    <!-- CARD -->
    <section class="bg-box-bg border border-box-border rounded-2xl shadow-sm p-8">

      <form id="postForm" class="space-y-6">

        <!-- TÍTULO -->
        <div>
          <label class="text-sm text-heading-3">Título</label>

          <input
            name="titulo"
            type="text"
            required
            placeholder="Digite o título do post"
            class="w-full mt-1 bg-body border border-box-border rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary"
          />
        </div>

        <!-- IMAGEM -->
        <div>
          <label class="text-sm text-heading-3">Imagem principal</label>

          <input
            id="imagem"
            type="file"
            accept="image/*"
            class="w-full mt-1 bg-body border border-box-border rounded-xl px-4 py-3"
          />

          <img
            id="preview"
            class="hidden mt-4 w-full max-h-64 object-cover rounded-xl border border-box-border"
          />
        </div>

        <!-- CONTEÚDO -->
        <div>
          <label class="text-sm text-heading-3">Conteúdo</label>

          <textarea
            name="conteudo"
            required
            placeholder="Escreva o conteúdo do artigo..."
            class="w-full mt-1 bg-body border border-box-border rounded-xl px-4 py-3 h-72 focus:outline-none focus:ring-2 focus:ring-primary"
          ></textarea>
        </div>

        <!-- ACTIONS -->
        <div class="flex flex-col md:flex-row gap-4 md:items-center md:justify-between">

          <button
            id="submitBtn"
            type="submit"
            class="px-6 py-3 rounded-xl bg-primary text-white font-semibold hover:opacity-90 transition"
          >
            Publicar artigo
          </button>

          <span id="status" class="text-sm text-heading-3"></span>

        </div>

      </form>

    </section>

  </Container>

</main>

</Layout>

<!-- SCRIPT -->
<script type="module">

window.addEventListener("DOMContentLoaded", () => {

  const form = document.getElementById("postForm");
  const btn = document.getElementById("submitBtn");
  const status = document.getElementById("status");

  const imagemInput = document.getElementById("imagem");
  const preview = document.getElementById("preview");

  if (!form || !btn || !status || !imagemInput || !preview) return;

  // preview imagem
  imagemInput.addEventListener("change", () => {
    const file = imagemInput.files?.[0];
    if (!file) return;

    preview.src = URL.createObjectURL(file);
    preview.classList.remove("hidden");
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    btn.disabled = true;
    status.textContent = "Publicando...";

    try {
      let imagemUrl = "";

      const file = imagemInput.files?.[0];

      // upload blob
      if (file) {
        status.textContent = "Enviando imagem...";

        const formData = new FormData();
        formData.append("file", file);

        const res = await fetch("/api/upload", {
          method: "POST",
          body: formData,
        });

        const data = await res.json();

        if (!res.ok) throw new Error(data.error || "Erro no upload");

        imagemUrl = data.url;
      }

      status.textContent = "Salvando post...";

      const post = {
        titulo: form.querySelector('[name="titulo"]').value,
        conteudo: form.querySelector('[name="conteudo"]').value,
        imagem: imagemUrl,
      };

      const response = await fetch("/api/posts", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(post),
      });

      const result = await response.json();

      if (!response.ok) throw new Error(result.error);

      status.textContent = "Post publicado com sucesso ✅";
      status.className = "text-green-500 text-sm";

      form.reset();
      preview.classList.add("hidden");

    } catch (err) {
      status.textContent = err.message || "Erro inesperado";
      status.className = "text-red-500 text-sm";

    } finally {
      btn.disabled = false;
    }
  });

});

</script>