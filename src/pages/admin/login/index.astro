<html lang="pt-br">
  <head>
    <title>Login Admin</title>
  </head>

  <body>

    <section class="min-h-screen flex items-center justify-center px-6">

      <form class="w-full max-w-md border rounded-3xl p-8 shadow-xl bg-white">

        <h1 class="text-3xl font-bold mb-8">
          Login Admin
        </h1>

        <input
          type="email"
          placeholder="Seu e-mail"
          class="w-full border rounded-xl px-4 py-3 mb-4"
        />

        <input
          type="password"
          placeholder="Sua senha"
          class="w-full border rounded-xl px-4 py-3 mb-6"
        />

        <button
          class="w-full bg-primary text-white py-3 rounded-xl"
        >
          Entrar
        </button>

      </form>

    </section>

  </body>
</html>