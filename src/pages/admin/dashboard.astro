---
import "../../styles/global.css";
---

<html lang="pt-br">
  <head>
    <title>Dashboard ERP</title>
  </head>

  <body class="bg-body">

    <section class="max-w-7xl mx-auto py-16 px-6">

      <!-- HEADER -->
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-10">

        <div>
          <h1 class="text-4xl font-bold text-heading-1">
            Dashboard
          </h1>

          <p class="text-heading-3 mt-2">
            Painel administrativo do sistema
          </p>
        </div>

        <a
          href="/admin/posts/criar"
          class="bg-primary text-white px-6 py-3 rounded-xl font-semibold hover:opacity-90 transition"
        >
          + Novo Post
        </a>

      </div>

      <!-- CARDS ERP -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-box-bg border border-box-border rounded-2xl p-6">
          <p class="text-heading-3">Total de Posts</p>
          <h2 class="text-3xl font-bold mt-2">24</h2>
        </div>

        <div class="bg-box-bg border border-box-border rounded-2xl p-6">
          <p class="text-heading-3">Publicados</p>
          <h2 class="text-3xl font-bold mt-2">18</h2>
        </div>

        <div class="bg-box-bg border border-box-border rounded-2xl p-6">
          <p class="text-heading-3">Rascunhos</p>
          <h2 class="text-3xl font-bold mt-2">6</h2>
        </div>

      </div>

      <!-- LISTA DE POSTS -->
      <div class="mt-10 bg-box-bg border border-box-border rounded-2xl p-6">

        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold">Últimos Posts</h2>
        </div>

        <div id="postsList" class="space-y-4">
          <!-- JS vai preencher aqui -->
        </div>

      </div>

    </section>

  </body>

  <script type="module">
    async function loadPosts() {
      const res = await fetch("/api/posts");
      const posts = await res.json();

      const container = document.getElementById("postsList");

      container.innerHTML = posts.map(post => `
        <div class="flex items-center justify-between p-4 border border-box-border rounded-xl">

          <div>
            <h3 class="font-semibold">${post.titulo}</h3>
            <p class="text-sm text-gray-400">${post.slug}</p>
          </div>

          <div class="flex gap-3">
            <a href="/admin/editar/${post.id}" class="text-blue-400">Editar</a>
            <button onclick="deletePost('${post.id}')" class="text-red-400">Excluir</button>
          </div>

        </div>
      `).join("");
    }

    async function deletePost(id) {
      await fetch(`/api/posts/${id}`, {
        method: "DELETE"
      });

      location.reload();
    }

    loadPosts();
  </script>

</html>